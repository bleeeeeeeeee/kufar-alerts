# Токен бота от @BotFather
BOT_TOKEN=your_telegram_bot_token

# Telegram ID администраторов (через запятую). Узнать ID: @userinfobot
ADMIN_USER_IDS=123456789

# Режим доступа: invite (по приглашению) | open (любой может войти)
ACCESS_MODE=invite

# Интервал проверки новых объявлений (секунды)
POLL_INTERVAL=45

# Путь к базе данных SQLite (на Railway — volume /app/data)
DATABASE_PATH=data/kufar_alerts.db

# Сколько объявлений запрашивать за один опрос
SEARCH_SIZE=50
